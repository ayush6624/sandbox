# Copy to config.env (gitignored) and fill in, then run ./vms.sh up
#   cp config.env.example config.env
# Sourced by vms.sh — plain shell assignments only. Do NOT commit secrets.

PROJECT="my-gcp-project"           # GCP project
ZONE="asia-south1-a"               # Mumbai (GCP equivalent of AWS ap-south-1)

# Instances
NAMES=(testvm-1 testvm-2)          # one VM per name
MACHINE_TYPE="n2-standard-8"       # 8 vCPU / 32 GB RAM
DISK_SIZE="256GB"                  # boot disk size (OS + kernel + binaries)
DISK_TYPE="pd-ssd"                 # SSD-backed persistent disk
# Data disk: a separate XFS volume (reflink=1) for the base rootfs, per-sandbox
# rootfs copies, and snapshot artifacts. XFS reflink gives instant copy-on-write
# clones (cp --reflink) — the key to fast snapshot fan-out; the ext4 boot disk
# can't reflink. Formatted + mounted at /mnt/sandbox-data by
# scripts/gcp-host-bootstrap.sh. Required by vms.sh (no default).
DATA_DISK_SIZE="1TB"               # XFS data disk size
DATA_DISK_TYPE="pd-ssd"
IMAGE_FAMILY="ubuntu-2404-lts-amd64"
IMAGE_PROJECT="ubuntu-os-cloud"

# Spot (preemptible) instances: much cheaper, but can be reclaimed by GCP at any
# time. "true" = spot, "false" = standard. On reclaim the VM is stopped (not
# deleted) so the disk survives — set TERMINATION_ACTION=DELETE to delete instead.
SPOT="true"
TERMINATION_ACTION="STOP"

# Guest user (created with passwordless sudo by startup.sh)
SSH_USER="ayush"

# GCS snapshot durability: bucket for cross-host snapshot storage. Must match
# "snapshot_bucket" in configs/devbox-gcp.json. Managed by snapshot-store.sh
# (init creates bucket + sandbox-fleet-sa; attach wires the SA onto the VMs).
# When set, vms.sh attaches the SA to newly created VMs. Empty disables.
SNAPSHOT_BUCKET="my-gcp-project-sandbox-snapshots"

# Tailscale: reusable, EPHEMERAL auth key (tskey-auth-...). Leave empty to skip.
# Generate at https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=""

# Optional: SSH public key to authorize for $SSH_USER (for direct public-IP SSH).
# Leave empty if you only use Tailscale SSH.
SSH_PUBLIC_KEY=""

# =====================================================================
# Autoscaling (Nomad + MIG) — used by bake-image.sh, control.sh, mig.sh,
# deploy-job.sh. The static NAMES fleet above (vms.sh + fleet-deploy.sh) is
# for one-off debug VMs; autoscaling replaces it with a control VM + a
# Managed Instance Group of workers. See infra/gcp/README.md.
# =====================================================================

# GCS bucket the Nomad job pulls sandbox/sandboxd binaries from. `make
# gcs-release` uploads under releases/<git-sha>/. May equal SNAPSHOT_BUCKET.
RELEASE_BUCKET="my-gcp-project-sandbox-releases"

# Control VM (nomad server + gateway + prometheus + autoscaler). Non-spot.
# e2-standard-2 (2 full vCPU / 8 GB): e2-medium's shared core starves sshd
# under the four services + the autoscaler loop.
CONTROL_NAME="sandbox-control"
CONTROL_MACHINE_TYPE="e2-standard-2"
CONTROL_INTERNAL_IP="10.160.0.100"   # reserved static internal IP (in the subnet)

# Worker MIG. Workers are NON-SPOT by default — running sandboxes must not be
# preempted (see memory prod-hosts-nonspot). Flip WORKER_SPOT=true only for
# cost-saving dev fleets where eviction is acceptable.
# Sized for 1000 concurrent sandboxes: 48 slots/host x MIG_MAX=22 = 1056.
# n2-standard-16 (64 GiB) fits 48 x ~1.15 GiB guests + serve + headroom at the
# same 6:1 vCPU oversubscription as the old n2-standard-8/24-slot shape, with
# half the blast radius of n2-standard-32/96 when a host is scaled in or lost.
WORKER_SPOT="false"
WORKER_MACHINE_TYPE="n2-standard-16"
WORKER_DATA_DISK_SIZE="256GB"
# Boot disk must be >= the baked image size (bake-image.sh uses DISK_SIZE, 256GB
# by default). Shrink DISK_SIZE before baking to make this smaller.
WORKER_BOOT_DISK_SIZE="256GB"
WORKER_IMAGE_FAMILY="sandbox-worker"  # built by bake-image.sh
# Golden data-disk image family, built by `./bake-image.sh golden` (run AFTER
# `bake`). When present, mig.sh seeds each worker's data disk from it so serve
# adopts a pre-built golden instead of copying the rootfs + cold-building one.
# Absent = blank data disks + cold golden build (original behavior).
GOLDEN_DATA_IMAGE_FAMILY="sandbox-golden-data"
MIG_NAME="sandbox-workers"
MIG_MIN="2"                           # no scale-to-zero (a cold fleet 503s)
MIG_MAX="22"                          # hard cost guardrail: ceil(1000/48)+1

# Autoscaler policy inputs. SLOTS_PER_HOST is the source of truth for per-host
# RUNNING capacity: deploy-job.sh GENERATES the pools in devbox-gcp.json from it
# (taps = IPs = N), sizes the Nomad task's cgroup from it, AND sets
# mem_budget_mib = N x MEM_PER_SLOT_MIB — the sum-of-guest-memory admission
# ceiling that keeps mem_mib overrides from oversubscribing a host past its
# cgroup. The ceiling on N is the guest subnet width (GUEST_SUBNET_BITS below):
# /24 ~253, /22 ~1021, /20 ~4093.
SLOTS_PER_HOST="48"
HEADROOM_SLOTS="48"                   # static floor: keep one warm host's worth ahead of demand
LEAD_SECONDS="90"                     # lever 4b: also reserve rate(creates)*LEAD_SECONDS (demand
                                      # during a host's reaction window) when higher; 0 = static only

# Port pool size for explicit guest-port mappings, independent of VM capacity.
# Hibernated sandboxes retain their mappings for wake-on-connect. Default is
# 4x SLOTS_PER_HOST, leaving room for multiple services per sandbox.
# PORTS_PER_HOST="192"

# Guest subnet width (prefix bits) — the HARD ceiling on concurrently RUNNING
# sandboxes per host (each needs one guest IP). Default 24 (~253 usable). Widen
# to /22 (~1021) or /20 (~4093) AND raise SLOTS_PER_HOST to run more small
# sandboxes at once; deploy-job.sh spans the guest-IP pool across octets and
# refuses a SLOTS_PER_HOST that won't fit. The host applies it to the gateway
# CIDR, the cold-boot guest CIDR, and the clone-path MMDS reidentify prefix.
# GUEST_SUBNET_BITS="24"

# Committed memory charged per running slot = avg guest mem_mib + ~156 MiB VMM
# overhead. Default 1180 (1 GiB guest). LOWER it for a small-sandbox fleet (128
# MiB guests -> ~300) so mem_budget_mib and the cgroup shrink per slot and the
# same host RAM admits many more running sandboxes. TASK_MEMORY (cgroup) =
# SLOTS_PER_HOST x this + 2000 — keep within the worker machine's RAM.
# MEM_PER_SLOT_MIB="1180"
SCALE_DOWN_WINDOW="15m"               # desired must stay low this long before scale-in

# Gateway create queue. queue-wait must cover the slowest common capacity path:
# MIG resize -> standby VM start -> nomad join -> serve up + golden snapshot
# build -> first warm heartbeat (~2-3 min all-in). queue-max bounds concurrent
# waiters; beyond it creates 503 immediately (with Retry-After).
QUEUE_WAIT="180s"
QUEUE_MAX="4096"

# Production policy: demand is predictable, so keep the full standby pool
# suspended and replenish it ahead of forecast demand. Stopped VMs remain
# supported as a cheaper fallback, but are intentionally disabled here. Set
# both sizes to 0 to disable standby. Change a live MIG with ./mig.sh standby.
STANDBY_SUSPENDED_SIZE="6"
STANDBY_STOPPED_SIZE="0"
STANDBY_INITIAL_DELAY="180"           # secs before a new standby VM is suspended/stopped
                                      # (covers startup-worker.sh + Nomad + serve initialization)

# Pinned tool versions (baked into the worker image / installed on control).
NOMAD_VERSION="1.7.7"
AUTOSCALER_VERSION="0.4.6"
